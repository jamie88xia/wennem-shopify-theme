[
  {
    "name": "Brand",
    "settings": [
      {
        "type": "text",
        "id": "brand_name",
        "label": "Brand name",
        "default": "WENNEM"
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width",
        "min": 80,
        "max": 220,
        "step": 10,
        "unit": "px",
        "default": 130
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Primary background",
        "default": "#F8F6F2"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Secondary background",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Primary text",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text",
        "default": "#6B6B6B"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#C6A66A"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Borders",
        "default": "#ECE9E3"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Body font",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "base_font_size",
        "label": "Base font size",
        "min": 14,
        "max": 18,
        "step": 1,
        "unit": "px",
        "default": 15
      },
      {
        "type": "range",
        "id": "heading_scale",
        "label": "Heading scale",
        "min": 85,
        "max": 120,
        "step": 5,
        "unit": "%",
        "default": 100
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "section_spacing",
        "label": "Section spacing",
        "min": 48,
        "max": 140,
        "step": 4,
        "unit": "px",
        "default": 88
      },
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width",
        "min": 1120,
        "max": 1680,
        "step": 40,
        "unit": "px",
        "default": 1440
      },
      {
        "type": "range",
        "id": "button_radius",
        "label": "Button radius",
        "min": 0,
        "max": 24,
        "step": 1,
        "unit": "px",
        "default": 2
      },
      {
        "type": "select",
        "id": "button_style",
        "label": "Button style",
        "options": [
          { "value": "solid", "label": "Solid primary" },
          { "value": "outline", "label": "Outline primary" }
        ],
        "default": "solid"
      },
      {
        "type": "select",
        "id": "product_card_ratio",
        "label": "Product image ratio",
        "options": [
          { "value": "3 / 4", "label": "Portrait" },
          { "value": "4 / 5", "label": "Tall portrait" },
          { "value": "1 / 1", "label": "Square" }
        ],
        "default": "4 / 5"
      }
    ]
  },
  {
    "name": "Commerce",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_product_badges",
        "label": "Show product badges",
        "default": true
      },
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold in cents",
        "default": 25000
      }
    ]
  }
