{% liquid
  assign card_product = product
  assign first_variant = card_product.selected_or_first_available_variant
  assign second_image = card_product.media[1]
%}

<article class="product-card fade-in">
  <div class="product-card__media">
    {% if settings.show_product_badges and card_product.tags contains 'New' %}
      <span class="badge">New</span>
    {% elsif settings.show_product_badges and card_product.compare_at_price > card_product.price %}
      <span class="badge">Sale</span>
    {% endif %}

    <button class="wishlist" type="button" aria-label="Add {{ card_product.title | escape }} to wishlist">♡</button>

    <a href="{{ card_product.url }}" aria-label="{{ card_product.title | escape }}">
      {% if card_product.featured_image %}
        {{ card_product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width: 1000px) 25vw, 50vw', alt: card_product.featured_image.alt | default: card_product.title }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag }}
      {% endif %}

      {% if second_image %}
        {{ second_image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width: 1000px) 25vw, 50vw', alt: second_image.alt | default: card_product.title }}
      {% endif %}
    </a>

    <div class="quick-actions">
      {% if first_variant %}
        {% form 'product', card_product, class: 'quick-add-form' %}
          <input type="hidden" name="id" value="{{ first_variant.id }}">
          <button class="button button--primary button--full" type="submit" {% unless first_variant.available %}disabled{% endunless %}>
            {% if first_variant.available %}Quick Add{% else %}Sold Out{% endif %}
          </button>
        {% endform %}
      {% endif %}
      <button class="button" type="button" data-quick-view>View</button>
    </div>
  </div>

  <div class="product-card__info">
    <a class="product-card__title" href="{{ card_product.url }}">{{ card_product.title }}</a>
    {% if card_product.metafields.custom.available_inseams != blank %}
      <span class="product-card__meta">{{ card_product.metafields.custom.available_inseams.value | default: card_product.metafields.custom.available_inseams }}</span>
    {% endif %}
    <div class="product-card__price">{% if card_product.price_varies %}From {% endif %}{% render 'price-display', product: card_product, variant: first_variant %}</div>
  </div>
</article>
