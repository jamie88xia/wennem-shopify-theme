<section class="section">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      {% if section.settings.link_label != blank %}
        <a class="button" href="{{ section.settings.link | default: '/collections/products' }}">{{ section.settings.link_label }}</a>
      {% endif %}
    </div>
    <div class="product-grid">
      {% assign collection = section.settings.collection %}
      {% if collection.products_count > 0 %}
        {% for product in collection.products limit: section.settings.limit %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <article class="product-card fade-in">
            <div class="product-card__media"><img src="{{ 'wennem-hero.png' | asset_url }}" width="1693" height="929" alt="Editorial product placeholder"></div>
            <div class="product-card__info"><span class="product-card__title">Tailored Essential {{ i }}</span><span class="product-card__price">$198</span></div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New arrivals" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The refined essentials edit." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products", "min": 3, "max": 12, "step": 1, "default": 4 },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View all" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
