<section class="section size-guide">
  <div class="page-width">
    <div class="section-heading">
      <div>
        {% if section.settings.eyebrow != blank %}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
        <h1>{{ section.settings.heading }}</h1>
      </div>
      <p>{{ section.settings.copy }}</p>
    </div>

    <div class="guide-grid">
      <article class="guide-card">
        <h2>Body measurements</h2>
        <div class="table-wrap">
          <table>
            <caption class="visually-hidden">Body measurements by size</caption>
            <thead><tr><th>Size</th><th>Waist</th><th>Hip</th><th>Recommended height</th></tr></thead>
            <tbody>
              <tr><th>00</th><td>24"</td><td>34"</td><td>5'4" and under</td></tr>
              <tr><th>0</th><td>25"</td><td>35"</td><td>5'4" and under</td></tr>
              <tr><th>2</th><td>26"</td><td>36"</td><td>5'4" and under</td></tr>
              <tr><th>4</th><td>27"</td><td>37"</td><td>5'4" and under</td></tr>
              <tr><th>6</th><td>28"</td><td>38"</td><td>5'4" and under</td></tr>
            </tbody>
          </table>
        </div>
      </article>

      <article class="guide-card">
        <h2>Petite inseam guide</h2>
        <div class="table-wrap">
          <table>
            <caption class="visually-hidden">Petite inseam reference</caption>
            <thead><tr><th>Length</th><th>Best for</th><th>Styling note</th></tr></thead>
            <tbody>
              <tr><th>26"</th><td>Full length on many shoppers 5'1" and under</td><td>Works with flats and low heels</td></tr>
              <tr><th>27"</th><td>Full length on many shoppers 5'2"-5'4"</td><td>Polished with loafers or boots</td></tr>
              <tr><th>28"</th><td>Slight break or heel-friendly length</td><td>Best when you prefer extra drape</td></tr>
            </tbody>
          </table>
        </div>
      </article>
    </div>

    <div class="measure-steps">
      <article>
        <h2>How to measure</h2>
        <p><strong>Rise:</strong> Measure from the top of the waistband to the crotch seam.</p>
        <p><strong>Inseam:</strong> Measure from the crotch seam to the hem along the inside leg.</p>
        <p><strong>Leg opening:</strong> Measure straight across the hem, then double it.</p>
      </article>
      <article>
        <h2>For the two-product launch</h2>
        <p>{{ section.settings.launch_note }}</p>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Size guide",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Fit reference" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Petite size guide" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Use this as a starting point, then check each product page for garment-specific rise, inseam, and leg measurements." },
    { "type": "textarea", "id": "launch_note", "label": "Launch note", "default": "WENNEM starts with two trouser styles. Each product page can expose its own garment measurements through metafields as the fit library expands." }
  ]
}
{% endschema %}
