<section class="section">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>
    </div>
    <div class="collection-grid">
      {% for block in section.blocks %}
        {% assign collection = block.settings.collection %}
        <a class="collection-card fade-in" href="{{ collection.url | default: block.settings.link }}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width: 1000px) 20vw, 50vw', alt: block.settings.title }}
          {% elsif collection.featured_image %}
            {{ collection.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width: 1000px) 20vw, 50vw', alt: collection.title }}
          {% else %}
            <img src="{{ 'wennem-hero-studio.png' | asset_url }}" alt="{{ block.settings.title | escape }}">
          {% endif %}
          <span>{{ block.settings.title | default: collection.title }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collections",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated edits" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by wardrobe moment." }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Title", "default": "New Arrivals" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Fallback link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collections",
      "blocks": [
        { "type": "collection", "settings": { "title": "New Arrivals" } },
        { "type": "collection", "settings": { "title": "Best Sellers" } },
        { "type": "collection", "settings": { "title": "Workwear" } },
        { "type": "collection", "settings": { "title": "Dresses" } },
        { "type": "collection", "settings": { "title": "Accessories" } }
      ]
    }
  ]
}
{% endschema %}
