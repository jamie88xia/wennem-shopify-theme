<section class="section">
  <div class="page-width narrow-page center-page">
    <p class="eyebrow">404</p>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.copy }}</p>
    <a class="button button--primary" href="{{ routes.root_url }}">Return home</a>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "This page is no longer in the fitting room." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Return to WENNEM and continue exploring petite workwear." }
  ]
}
{% endschema %}
