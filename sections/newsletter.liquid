<section class="section">
  <div class="page-width newsletter">
    <div>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.copy }}</p>
    </div>
    {% form 'customer', class: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" autocomplete="email" placeholder="Email address" aria-label="Email address" required>
      <button type="submit">Subscribe</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Private list" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Receive the edit before it arrives." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Early access, fit notes, care guidance, and quiet launches." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
