{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
  assign gallery_layout = section.settings.gallery_layout | default: 'mural'
%}

<section class="page-width product-page product-page--{{ gallery_layout }}">
  {% if gallery_layout == 'carousel' %}
    <div class="product-gallery product-gallery--carousel" data-product-gallery>
      <div class="product-gallery__viewport" aria-live="polite">
        {% for media in product.media %}
          <div class="product-gallery__slide{% if forloop.first %} is-active{% endif %}" data-gallery-slide data-gallery-index="{{ forloop.index0 }}"{% unless forloop.first %} hidden{% endunless %}>
            {% case media.media_type %}
              {% when 'image' %}
                {{ media | image_url: width: 1200 | image_tag: loading: 'eager', sizes: '(min-width: 1000px) 44vw, 100vw', alt: media.alt | default: product.title }}
              {% when 'video' %}
                {{ media | video_tag: controls: true, image_size: '1200x' }}
              {% when 'external_video' %}
                {{ media | external_video_tag }}
              {% else %}
                {{ media | media_tag }}
            {% endcase %}
          </div>
        {% else %}
          <div class="product-gallery__slide is-active" data-gallery-slide data-gallery-index="0">
            <img src="{{ 'wennem-hero.png' | asset_url }}" width="1693" height="929" alt="{{ product.title | escape }}">
          </div>
          <div class="product-gallery__slide" data-gallery-slide data-gallery-index="1" hidden>
            <img src="{{ 'wennem-hero-studio.png' | asset_url }}" width="1536" height="1024" alt="{{ product.title | escape }}">
          </div>
        {% endfor %}
      </div>

      <div class="product-gallery__thumbs" aria-label="Product media">
        {% for media in product.media %}
          <button class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}" type="button" data-gallery-thumb data-gallery-index="{{ forloop.index0 }}" aria-label="Show media {{ forloop.index }}" aria-current="{% if forloop.first %}true{% else %}false{% endif %}">
            {% if media.preview_image %}
              {{ media.preview_image | image_url: width: 160 | image_tag: loading: 'lazy', sizes: '72px', alt: media.alt | default: product.title }}
            {% else %}
              <span>{{ forloop.index }}</span>
            {% endif %}
          </button>
        {% else %}
          <button class="product-gallery__thumb is-active" type="button" data-gallery-thumb data-gallery-index="0" aria-label="Show media 1" aria-current="true">
            <img src="{{ 'wennem-hero.png' | asset_url }}" width="80" height="44" alt="{{ product.title | escape }}">
          </button>
          <button class="product-gallery__thumb" type="button" data-gallery-thumb data-gallery-index="1" aria-label="Show media 2" aria-current="false">
            <img src="{{ 'wennem-hero-studio.png' | asset_url }}" width="80" height="53" alt="{{ product.title | escape }}">
          </button>
        {% endfor %}
      </div>
    </div>
  {% else %}
    <div class="product-gallery product-gallery--mural">
      {% for media in product.media %}
        <div class="product-gallery__tile">
          {% case media.media_type %}
            {% when 'image' %}
              {{ media | image_url: width: 1100 | image_tag: loading: 'lazy', sizes: '(min-width: 1000px) 34vw, 100vw', alt: media.alt | default: product.title }}
            {% when 'video' %}
              {{ media | video_tag: controls: true, image_size: '1000x' }}
            {% when 'external_video' %}
              {{ media | external_video_tag }}
            {% else %}
              {{ media | media_tag }}
          {% endcase %}
        </div>
      {% else %}
        <div class="product-gallery__tile">
          <img src="{{ 'wennem-hero.png' | asset_url }}" width="1693" height="929" alt="{{ product.title | escape }}">
        </div>
        <div class="product-gallery__tile">
          <img src="{{ 'wennem-hero-studio.png' | asset_url }}" width="1536" height="1024" alt="{{ product.title | escape }}">
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <div class="product-panel">
    {% render 'breadcrumbs', product: product, collection: collection %}
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ product.title }}</h1>
    {% if product.metafields.custom.subtitle != blank %}
      <p class="product-subtitle">{{ product.metafields.custom.subtitle.value | default: product.metafields.custom.subtitle }}</p>
    {% endif %}
    {% render 'price-display', product: product, variant: current_variant %}

    {% if product.metafields.custom.fit_summary != blank %}
      <div class="fit-summary">
        <h2>Petite fit summary</h2>
        <p>{{ product.metafields.custom.fit_summary.value | default: product.metafields.custom.fit_summary }}</p>
      </div>
    {% endif %}

    {% form 'product', product, id: product_form_id, class: 'product-form' %}
      <input type="hidden" name="id" value="{{ current_variant.id }}">

      {% unless product.has_only_default_variant %}
        {% for option in product.options_with_values %}
          <fieldset class="variant-group">
            <legend class="swatch-label">{{ option.name }}</legend>
            <div class="option-grid">
              {% for value in option.values %}
                <label class="option-pill">
                  <input class="visually-hidden" type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %}>
                  <span>{{ value }}</span>
                </label>
              {% endfor %}
            </div>
          </fieldset>
        {% endfor %}
      {% endunless %}

      <div class="variant-group">
        <p class="swatch-label">Quantity</p>
        {% render 'quantity-selector', label: 'product quantity' %}
      </div>

      <div class="purchase-actions" aria-label="Purchase actions">
        <button class="button button--primary button--full" type="submit" {% unless current_variant.available %}disabled{% endunless %}>
          {% if current_variant.available %}{{ section.settings.button_label }}{% else %}Sold Out{% endif %}
        </button>
        <a class="button button--full" href="/pages/size-guide">Size guide</a>
      </div>
    {% endform %}

    <div class="product-benefits">
      <p>{{ section.settings.benefit_1 }}</p>
      <p>{{ section.settings.benefit_2 }}</p>
      <p>{{ section.settings.benefit_3 }}</p>
    </div>

    <p class="microcopy">
      {% if current_variant.inventory_quantity > 0 and current_variant.inventory_quantity < 8 %}
        Only {{ current_variant.inventory_quantity }} left.
      {% else %}
        {{ section.settings.shipping_message }}
      {% endif %}
    </p>

    <div class="fit-tools">
      <div class="fit-tool">
        <span>Fit rating</span>
        <strong>{{ product.metafields.custom.fit_rating.value | default: product.metafields.custom.fit_rating | default: section.settings.fit_rating }}</strong>
      </div>
      <div class="fit-tool">
        <span>Recommended height</span>
        <strong>{{ product.metafields.custom.recommended_height_range.value | default: product.metafields.custom.recommended_height_range | default: section.settings.height_range }}</strong>
      </div>
      <div class="fit-tool">
        <span>Fabric stretch</span>
        <strong>{{ product.metafields.custom.stretch_level.value | default: product.metafields.custom.stretch_level | default: section.settings.stretch_level }}</strong>
      </div>
    </div>

    <div class="measurement-card">
      <h2>Garment measurements</h2>
      <dl>
        {% if product.metafields.custom.rise != blank %}<div><dt>Rise</dt><dd>{{ product.metafields.custom.rise.value | default: product.metafields.custom.rise }}</dd></div>{% endif %}
        {% if product.metafields.custom.inseam != blank %}<div><dt>Inseam</dt><dd>{{ product.metafields.custom.inseam.value | default: product.metafields.custom.inseam }}</dd></div>{% endif %}
        {% if product.metafields.custom.waist_measurement != blank %}<div><dt>Waist</dt><dd>{{ product.metafields.custom.waist_measurement.value | default: product.metafields.custom.waist_measurement }}</dd></div>{% endif %}
        {% if product.metafields.custom.hip_measurement != blank %}<div><dt>Hip</dt><dd>{{ product.metafields.custom.hip_measurement.value | default: product.metafields.custom.hip_measurement }}</dd></div>{% endif %}
        {% if product.metafields.custom.thigh_measurement != blank %}<div><dt>Thigh</dt><dd>{{ product.metafields.custom.thigh_measurement.value | default: product.metafields.custom.thigh_measurement }}</dd></div>{% endif %}
        {% if product.metafields.custom.leg_opening != blank %}<div><dt>Leg opening</dt><dd>{{ product.metafields.custom.leg_opening.value | default: product.metafields.custom.leg_opening }}</dd></div>{% endif %}
      </dl>
      {% if product.metafields.custom.rise == blank and product.metafields.custom.inseam == blank and product.metafields.custom.waist_measurement == blank %}
        <p>{{ section.settings.measurement_fallback }}</p>
      {% endif %}
    </div>

    <div class="model-card">
      <h2>Model reference</h2>
      <p>
        {{ product.metafields.custom.model_height.value | default: product.metafields.custom.model_height | default: section.settings.model_height }}
        wearing {{ product.metafields.custom.model_size.value | default: product.metafields.custom.model_size | default: section.settings.model_size }}
        {% if product.metafields.custom.model_inseam != blank %}
          with a {{ product.metafields.custom.model_inseam.value | default: product.metafields.custom.model_inseam }} inseam.
        {% endif %}
      </p>
    </div>

    <div class="accordion">
      <details open>
        <summary>Description <span>+</span></summary>
        <div>{{ product.description }}</div>
      </details>
      <details>
        <summary>Fit and sizing <span>+</span></summary>
        <p>{{ product.metafields.custom.fit_notes.value | default: product.metafields.custom.fit_notes | default: section.settings.size_guide }}</p>
      </details>
      <details>
        <summary>Materials <span>+</span></summary>
        <p>{{ product.metafields.custom.fabric_composition.value | default: product.metafields.custom.fabric_composition | default: section.settings.materials }}</p>
      </details>
      <details>
        <summary>Care instructions <span>+</span></summary>
        <p>{{ section.settings.care }}</p>
      </details>
      <details>
        <summary>Shipping and returns <span>+</span></summary>
        <p>{{ product.metafields.custom.shipping_note.value | default: product.metafields.custom.shipping_note | default: section.settings.returns }}</p>
      </details>
      <details>
        <summary>Styling notes <span>+</span></summary>
        <p>{{ product.metafields.custom.styling_notes.value | default: product.metafields.custom.styling_notes | default: section.settings.styling_notes }}</p>
      </details>
    </div>

    <div class="trust-badges">
      <span>{{ section.settings.trust_1 }}</span>
      <span>{{ section.settings.trust_2 }}</span>
      <span>{{ section.settings.trust_3 }}</span>
    </div>
  </div>
</section>

<div class="sticky-atc">
  <button class="button button--primary button--full" form="{{ product_form_id }}" type="submit">{{ section.settings.button_label }} · {{ current_variant.price | money }}</button>
</div>

{% schema %}
{
  "name": "Main product",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Pre-order" },
    { "type": "text", "id": "button_label", "label": "Purchase button label", "default": "Pre-order" },
    {
      "type": "select",
      "id": "gallery_layout",
      "label": "Gallery layout",
      "default": "mural",
      "options": [
        { "value": "mural", "label": "Mural" },
        { "value": "carousel", "label": "Carousel" }
      ]
    },
    { "type": "text", "id": "shipping_message", "label": "Shipping message", "default": "Free U.S. shipping on orders over $200." },
    { "type": "text", "id": "benefit_1", "label": "Benefit 1", "default": "Petite-first pattern" },
    { "type": "text", "id": "benefit_2", "label": "Benefit 2", "default": "Clean tailored fit" },
    { "type": "text", "id": "benefit_3", "label": "Benefit 3", "default": "Designed for all-day wear" },
    { "type": "text", "id": "trust_1", "label": "Trust badge 1", "default": "Free U.S. shipping over $200" },
    { "type": "text", "id": "trust_2", "label": "Trust badge 2", "default": "Pre-order support" },
    { "type": "text", "id": "trust_3", "label": "Trust badge 3", "default": "Secure checkout" },
    { "type": "textarea", "id": "size_guide", "label": "Fit and sizing fallback", "default": "Choose your usual size for a close, tailored fit. Between sizes, size up for ease." },
    { "type": "text", "id": "fit_rating", "label": "Fit rating fallback", "default": "True to size" },
    { "type": "text", "id": "height_range", "label": "Recommended height fallback", "default": "5'4\" and under" },
    { "type": "text", "id": "stretch_level", "label": "Stretch fallback", "default": "Structured with light ease" },
    { "type": "text", "id": "model_height", "label": "Model height fallback", "default": "Model is 5'2\"" },
    { "type": "text", "id": "model_size", "label": "Model size fallback", "default": "size 2" },
    { "type": "textarea", "id": "measurement_fallback", "label": "Measurement fallback", "default": "Detailed garment measurements can be added through product metafields as the first two styles are finalized." },
    { "type": "textarea", "id": "materials", "label": "Materials", "default": "Premium woven fabric selected for structure, drape, and recovery." },
    { "type": "textarea", "id": "care", "label": "Care instructions", "default": "Dry clean recommended. Steam gently between wears." },
    { "type": "textarea", "id": "returns", "label": "Returns", "default": "Complimentary exchanges within 30 days. Returns accepted on unworn pieces with original tags." },
    { "type": "textarea", "id": "styling_notes", "label": "Styling notes fallback", "default": "Designed to pair with refined shirting, soft knits, and tailored layers for office-to-evening wear." }
  ]
}
{% endschema %}
