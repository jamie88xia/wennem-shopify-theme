<section class="section">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <a class="button" href="{{ section.settings.link }}">Follow</a>
    </div>
    <div class="instagram-grid">
      {% for block in section.blocks %}
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', sizes: '(min-width: 1000px) 33vw, 100vw', alt: block.settings.alt }}
        {% else %}
          <img src="{{ 'wennem-hero-studio.png' | asset_url }}" alt="{{ block.settings.alt | escape }}">
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Instagram gallery",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Journal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Worn in the everyday." },
    { "type": "url", "id": "link", "label": "Social link" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text", "default": "Editorial social image" }
      ]
    }
  ],
  "presets": [
    { "name": "Instagram gallery", "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }] }
  ]
}
{% endschema %}
