<section class="section">
  <div class="page-width">
    <h1>Search</h1>
    <form class="search-form" action="{{ routes.search_url }}" method="get" role="search">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search the collection" aria-label="Search">
      <button type="submit">Search</button>
    </form>

    {% if search.performed %}
      <p class="product-count">{{ search.results_count }} results for "{{ search.terms }}"</p>
      <div class="product-grid">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            {% render 'product-card', product: item %}
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{ "name": "Search results", "settings": [] }
{% endschema %}
