<section class="section">
  <div class="page-width contact-layout">
    <div>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.copy }}</p>
    </div>

    {% form 'contact', class: 'contact-form' %}
      {% if form.posted_successfully? %}
        <p class="form-message" tabindex="-1">{{ section.settings.success }}</p>
      {% endif %}
      {% if form.errors %}
        <div class="form-message form-message--error">{{ form.errors | default_errors }}</div>
      {% endif %}

      <label>Name<input type="text" name="contact[name]" autocomplete="name"></label>
      <label>Email<input type="email" name="contact[email]" autocomplete="email" required></label>
      <label>Message<textarea name="contact[body]" rows="6" required></textarea></label>
      <button class="button button--primary" type="submit">Send message</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Contact" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Fit questions, order support, and thoughtful replies." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Send us a note and we will help with sizing, inseam questions, or order details." },
    { "type": "text", "id": "success", "label": "Success message", "default": "Thank you. We received your message." }
  ]
}
{% endschema %}
