<header class="site-header" aria-label="Primary">
  <div class="page-width header-inner">
    <button class="mobile-menu-button icon-button" type="button" aria-label="{{ 'general.accessibility.open_menu' | t }}" data-open-menu aria-controls="MobileMenu">☰</button>

    <nav class="nav" aria-label="Main navigation">
      {% if section.settings.menu != blank %}
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="{{ routes.root_url }}">Home</a>
        <a href="/collections/products">Products</a>
        <a href="/pages/our-story">Story</a>
        <a href="/pages/contact">Contact</a>
        <a href="/collections/pre-order">Pre-order</a>
      {% endif %}
    </nav>

    <a class="brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }} home" style="--logo-width: {{ settings.logo_width }}px">
      {% if settings.logo != blank %}
        {{ settings.logo | image_url: width: 440 | image_tag: alt: settings.brand_name }}
      {% else %}
        {{ settings.brand_name | default: shop.name }}
      {% endif %}
    </a>

    <div class="header-actions">
      <button type="button" data-open-search>Search</button>
      <a href="{{ routes.account_url }}">Account</a>
      <button type="button" data-open-cart>Bag <span>{{ cart.item_count }}</span></button>
    </div>
  </div>
</header>

<aside id="MobileMenu" class="drawer mobile-menu" data-mobile-menu hidden aria-label="Mobile menu">
  <div class="drawer-backdrop" data-layer-backdrop></div>
  <div class="drawer-panel drawer-panel--left">
    <div class="drawer-header">
      <h3>Menu</h3>
      <button class="icon-button" type="button" data-close-menu aria-label="{{ 'general.accessibility.close' | t }}">×</button>
    </div>

    <nav class="mobile-nav" aria-label="Mobile navigation">
      {% if section.settings.menu != blank %}
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="{{ routes.root_url }}">Home</a>
        <a href="/collections/products">Products</a>
        <a href="/pages/our-story">Story</a>
        <a href="/pages/contact">Contact</a>
        <a href="/collections/pre-order">Pre-order</a>
        <a href="/pages/size-guide">Size guide</a>
        <a href="/pages/faq">FAQ</a>
      {% endif %}
    </nav>

    <div class="mobile-menu__note">
      <p class="eyebrow">Petite workwear</p>
      <p>Two precise trouser styles to start, with a fit system built for shorter frames.</p>
    </div>
  </div>
</aside>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    }
  ]
}
{% endschema %}
