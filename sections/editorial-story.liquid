<section class="section">
  <div class="page-width split-editorial">
    <div class="fade-in">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', sizes: '(min-width: 1000px) 58vw, 100vw', alt: section.settings.heading }}
      {% else %}
        <img src="{{ 'wennem-hero-atelier.png' | asset_url }}" width="1536" height="1024" alt="{{ section.settings.heading | escape }}">
      {% endif %}
    </div>
    <div class="fade-in">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.copy }}</p>
      {% if section.settings.button_label != blank %}
        <a class="button" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial story",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Craft and fit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Luxury measured in proportion, hand, and restraint." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Every silhouette begins with fabric, balance, and the way a garment lives on the body. The result is an edited wardrobe that feels exact without feeling precious." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Read our story" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Editorial story" }]
}
{% endschema %}
