{% if section.settings.text != blank %}
  <div class="announcement" role="region" aria-label="Announcement">
    <span>{{ section.settings.text }}</span>
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "text", "id": "text", "label": "Text", "default": "Complimentary shipping on orders over $250" }
  ]
}
{% endschema %}
